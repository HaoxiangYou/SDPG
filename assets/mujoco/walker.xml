<mujoco model="walker">
    <!-- MJX variant of assets/walker.xml (dm_control planar walker): adds the ground
         plane (the genesis backend adds it programmatically) and MJX-friendly solver
         options, mirroring assets/mujoco/hopper.xml. The solver runs a fixed number of
         iterations (see externals/README.md, mujoco Patch 01), so keep
         iterations/ls_iterations small. timestep is overridden by task sim_options. -->
    <compiler angle="radian" />
    <option timestep="0.005" integrator="Euler" solver="Newton" iterations="4" ls_iterations="8" />
    <default>
        <joint damping="0.1" armature="0.01" limited="true" solimplimit="0 .99 .01" />
        <geom type="capsule" contype="1" conaffinity="0" friction="0.7 0.1 0.1" rgba="1.0 0.5 0.0 1" />
        <general ctrlrange="-1 1" ctrllimited="true" />
    </default>
    <worldbody>
        <light pos="0 0 1.3" dir="0 0 -1" directional="true" cutoff="100" exponent="1" diffuse="1 1 1" specular="0.1 0.1 0.1" />
        <!-- Finite render size: madrona scales the plane render mesh by (x, y), so the
             mujoco infinite-plane convention ("0 0 1") would be invisible (see
             assets/mujoco/hopper.xml). Collision stays infinite regardless of size. -->
        <geom name="floor" type="plane" conaffinity="1" size="50 50 1" pos="0 0 0" rgba="0.5 0.5 0.5 1" />
        <body name="torso" pos="0 0 1.3">
            <!-- Batch-render camera: tracks the torso position with fixed world
                 orientation (mode="track"), matching the genesis camera mount
                 (offset [0, -2, -0.5] from torso, looking along +y, fov 60). -->
            <camera name="track_cam" mode="track" pos="0 -2 -0.5" xyaxes="1 0 0 0 0 1" fovy="60" />
            <!-- Both slides are declared before the hinge so the translation axes stay
                 world-aligned. qpos root order is therefore [x, z(height), y(angle)];
                 the env permutes to the genesis walker observation order. -->
            <joint name="rootx" axis="1 0 0" type="slide" limited="false" armature="0" damping="0" />
            <joint name="rootz" axis="0 0 1" type="slide" limited="false" armature="0" damping="0" />
            <joint name="rooty" axis="0 1 0" type="hinge" limited="false" armature="0" damping="0" />
            <geom name="torso_geom" size="0.07 0.3" />
            <body name="right_thigh" pos="0 -0.05 -0.3">
                <joint name="right_hip" axis="0 -1 0" range="-0.349066 1.745329" />
                <geom name="right_thigh_geom" pos="0 0 -0.225" size="0.05 0.225" />
                <body name="right_leg" pos="0 0 -0.7">
                    <joint name="right_knee" axis="0 -1 0" pos="0 0 0.25" range="-2.617994 0" />
                    <geom name="right_leg_geom" size="0.04 0.25" />
                    <body name="right_foot" pos="0.06 0 -0.25">
                        <joint name="right_ankle" axis="0 -1 0" pos="-0.06 0 0" range="-0.785398 0.785398" />
                        <geom name="right_foot_geom" zaxis="1 0 0" size="0.05 0.1" />
                    </body>
                </body>
            </body>
            <body name="left_thigh" pos="0 0.05 -0.3">
                <joint name="left_hip" axis="0 -1 0" range="-0.349066 1.745329" />
                <geom name="left_thigh_geom" pos="0 0 -0.225" size="0.05 0.225" />
                <body name="left_leg" pos="0 0 -0.7">
                    <joint name="left_knee" axis="0 -1 0" pos="0 0 0.25" range="-2.617994 0" />
                    <geom name="left_leg_geom" size="0.04 0.25" />
                    <body name="left_foot" pos="0.06 0 -0.25">
                        <joint name="left_ankle" axis="0 -1 0" pos="-0.06 0 0" range="-0.785398 0.785398" />
                        <geom name="left_foot_geom" zaxis="1 0 0" size="0.05 0.1" />
                    </body>
                </body>
            </body>
        </body>
    </worldbody>
    <actuator>
        <general joint="right_hip" gear="100 0 0 0 0 0" />
        <general joint="right_knee" gear="50 0 0 0 0 0" />
        <general joint="right_ankle" gear="20 0 0 0 0 0" />
        <general joint="left_hip" gear="100 0 0 0 0 0" />
        <general joint="left_knee" gear="50 0 0 0 0 0" />
        <general joint="left_ankle" gear="20 0 0 0 0 0" />
    </actuator>
</mujoco>
